<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.Cursor?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>

<VBox alignment="CENTER" maxHeight="-Infinity" maxWidth="-Infinity" minHeight="50.0" minWidth="50.0" spacing="20.0" style="-fx-background-color: rgba(255,255,255,0.7); -fx-background-radius: 20;" stylesheets="@../../../css/default.css" xmlns="http://javafx.com/javafx/23.0.1" xmlns:fx="http://javafx.com/fxml/1" fx:controller="io.github.java_lan_multiplayer.client.popups.cards.PlanetsPopupController">
   <children>
      <Label style="-fx-font-size: 20; -fx-font-weight: bold;" text="%label.choose_planet" />
      <HBox alignment="CENTER" maxHeight="-Infinity" maxWidth="-Infinity" minHeight="-Infinity" minWidth="-Infinity" spacing="20.0">
         <children>
            <StackPane>
               <children>
                  <ImageView fx:id="cardImageView" fitHeight="350.0" fitWidth="230.0" pickOnBounds="true" preserveRatio="true" />
                  <Button fx:id="planetButton0" disable="true" maxHeight="-Infinity" maxWidth="-Infinity" minHeight="-Infinity" minWidth="-Infinity" mnemonicParsing="false" prefHeight="55.0" prefWidth="180.0" style="-fx-background-color: rgba(255,255,255,0.1); -fx-border-color: white;" translateY="-86.0" visible="false" />
                  <Button fx:id="planetButton1" disable="true" maxHeight="-Infinity" maxWidth="-Infinity" minHeight="-Infinity" minWidth="-Infinity" mnemonicParsing="false" prefHeight="55.0" prefWidth="180.0" style="-fx-background-color: rgba(255,255,255,0.1); -fx-border-color: white;" translateY="-14.0" visible="false" />
                  <Button fx:id="planetButton2" disable="true" maxHeight="-Infinity" maxWidth="-Infinity" minHeight="-Infinity" minWidth="-Infinity" mnemonicParsing="false" prefHeight="55.0" prefWidth="180.0" style="-fx-background-color: rgba(255,255,255,0.1); -fx-border-color: white;" translateY="58.0" visible="false" />
                  <Button fx:id="planetButton3" disable="true" maxHeight="-Infinity" maxWidth="-Infinity" minHeight="-Infinity" minWidth="-Infinity" mnemonicParsing="false" prefHeight="55.0" prefWidth="180.0" style="-fx-background-color: rgba(255,255,255,0.1); -fx-border-color: white;" translateY="130.0" visible="false" />
               </children>
            </StackPane>
              <Button onAction="#onDecline" style="-fx-font-size: 14;" text="%button.decline_planet">
                 <cursor>
                     <Cursor fx:constant="HAND" />
                 </cursor>
              </Button>
         </children>
      </HBox>
   </children>
   <padding>
      <Insets bottom="20.0" left="20.0" right="20.0" top="20.0" />
   </padding>
</VBox>
