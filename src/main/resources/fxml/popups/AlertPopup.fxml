<?xml version="1.0" encoding="UTF-8"?>

<?import java.net.URL?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.Cursor?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.image.Image?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<HBox alignment="CENTER_RIGHT" maxHeight="-Infinity" maxWidth="-Infinity" minHeight="-Infinity" minWidth="-Infinity" prefHeight="250.0" prefWidth="550.0" spacing="20.0" styleClass="popup-root" xmlns="http://javafx.com/javafx/23.0.1" xmlns:fx="http://javafx.com/fxml/1" fx:controller="io.github.java_lan_multiplayer.client.popups.AlertPopupController">
    <padding>
        <Insets bottom="20.0" left="20.0" right="35.0" top="20.0" />
    </padding>
    <VBox alignment="CENTER" spacing="20">
        <Label fx:id="title" style="-fx-font-size: 18; -fx-font-weight: bold;" text="Title" textAlignment="CENTER" wrapText="true" />
        <Label fx:id="description" style="-fx-font-size: 16; -fx-text-fill: #444444;" text="Description" textAlignment="CENTER" textFill="#363636" wrapText="true" />
        <Button cancelButton="true" defaultButton="true" onAction="#onClose" style="-fx-font-size: 14;" text="%button.ok">
          <cursor>
              <Cursor fx:constant="HAND" />
          </cursor>
        </Button>
    </VBox>
    <ImageView fitHeight="150.0" fitWidth="200.0" pickOnBounds="true" preserveRatio="true">
        <Image url="@../../textures/icons/alert.png" />
    </ImageView>
   <stylesheets>
      <URL value="@../../css/default.css" />
      <URL value="@../../css/popup.css" />
   </stylesheets>
</HBox>
